{
  "name": "simple-weather-app",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git@github.com:mintbandit/simple-weather-app.git"
  },
  "scripts": {
    "dev": "concurrently \"pnpm dev:tailwind\" \"pnpm dev:backend\" \"pnpm dev:frontend\" \"pnpm dev:reload\"",
    "dev:tailwind": "tailwindcss -w -i src/backend/templates/index.css -o dist/styles.css",
    "dev:backend": "nodemon -w ./src -e ts,njk,css --exec ts-node src/backend/server.ts",
    "dev:reload": "pnpm livereload -w 2500 -e html,css,njk,ts",
    "dev:frontend": "nodemon -w ./src -e ts --exec node build-frontend.js",
    "test": "jest",
    "lint": "eslint",
    "check": "node check.js"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@tsconfig/strictest": "^2.0.8",
    "@types/babelify": "^7.3.10",
    "@types/browserify": "^12.0.40",
    "@types/core-js": "^2.5.8",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.43",
    "@types/nunjucks": "^3.2.6",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "axios-mock-adapter": "^1.22.0",
    "babelify": "^10.0.0",
    "browserify": "^17.0.1",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.2",
    "eslint-config-standard-with-typescript": "^34.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^15.7.0",
    "eslint-plugin-promise": "^6.6.0",
    "glob": "^10.5.0",
    "jest": "^29.7.0",
    "livereload": "^0.9.3",
    "nodemon": "^2.0.22",
    "path": "^0.12.7",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsify": "^5.0.4",
    "typescript": "^5.9.3",
    "uglifyify": "^5.0.2"
  },
  "engines": {
    "node": ">=18.9.1"
  },
  "dependencies": {
    "@fastify/formbody": "^7.4.0",
    "@fastify/static": "^6.12.0",
    "axios": "^1.18.1",
    "dotenv": "^17.4.2",
    "fastify": "^4.29.1",
    "nunjucks": "^3.2.4",
    "zod": "^4.4.3"
  }
}


